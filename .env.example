# AWS Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Auth Secrets
ENCRYPTION_KEY=          # Master key for JWE token encryption (64 hex chars / 32 bytes)
CLIENT_KEY=              # Validated against X-Poripurok-Client-Key header
AGENT_KEY=               # Mobile app agent key

# SMS (GreenWeb BD)
GREENWEB_SMS_TOKEN=

# CloudWatch
CLOUDWATCH_LOG_GROUP=/poripurok/api

# DynamoDB
DYNAMODB_TABLE=poripurok
